# Leprechaun Trading Bot - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application Settings
# =============================================================================
ENV=development
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production
LOG_LEVEL=INFO
LOG_FORMAT=json  # 'json' for production, 'human' for development

# =============================================================================
# Database (MariaDB)
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=leprechaun
DB_USER=leprechaun
DB_PASSWORD=your-db-password
DB_POOL_SIZE=5
DB_POOL_RECYCLE=3600

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# Alpaca Trading API
# Sign up at: https://alpaca.markets
# =============================================================================
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_PAPER=true  # Set to false for live trading

# =============================================================================
# Reddit API (PRAW)
# Create app at: https://www.reddit.com/prefs/apps
# Select "script" type for personal use
# =============================================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=Leprechaun/1.0
REDDIT_SUBREDDITS=wallstreetbets,stocks,investing

# =============================================================================
# Finnhub API
# Sign up at: https://finnhub.io
# =============================================================================
FINNHUB_API_KEY=your-finnhub-api-key

# =============================================================================
# StockTwits API (via RapidAPI)
# Sign up at: https://rapidapi.com
# Search for StockTwits endpoint
# =============================================================================
STOCKTWITS_API_KEY=your-rapidapi-key
STOCKTWITS_API_HOST=stocktwits.p.rapidapi.com

# =============================================================================
# Discord Notifications
# Create webhook in your Discord channel settings
# =============================================================================
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
DISCORD_ENABLED=true

# =============================================================================
# Firebase Push Notifications
# Create project at: https://console.firebase.google.com
# Download service account JSON from Project Settings > Service Accounts
# =============================================================================
FIREBASE_CREDENTIALS_PATH=
FIREBASE_ENABLED=false

# =============================================================================
# Trading Parameters
# These can be left at defaults or customized
# =============================================================================
PROFIT_TARGET_PERCENT=2.5
STOP_LOSS_PERCENT=1.25
POSITION_RISK_PERCENT=1.0
DAILY_LOSS_LIMIT_PERCENT=2.0
WEEKLY_LOSS_LIMIT_PERCENT=5.0
RSI_OVERSOLD=35
RSI_NORMALIZED=50
MANIPULATION_THRESHOLD=0.5
SENTIMENT_NEGATIVE_THRESHOLD=-0.4
